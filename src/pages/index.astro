---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="我的个人博客" description="记录技术与生活的个人空间">
  <section class="hero">
    <h1>欢迎来到我的博客</h1>
    <p>在这里记录技术探索、学习笔记和生活感悟</p>
  </section>

  <section>
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; padding-bottom: 0.75rem; border-bottom: 2px solid var(--color-border);">
      <h2 style="font-size: 1.3rem; font-weight: 700;">最新文章</h2>
      <a href={`${base}/rss.xml`} class="rss-link">📡 RSS 订阅</a>
    </div>

    <div class="post-list">
      {posts.map((post) => {
        const formattedDate = post.data.pubDate.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <article class="post-card">
            <h3>
              <a href={`${base}/blog/${post.id}/`}>{post.data.title}</a>
            </h3>
            <div class="post-meta">
              <span>📅 {formattedDate}</span>
            </div>
            <p class="post-description">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.map((tag: string) => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
            )}
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
